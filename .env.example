SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_REPLY_TABLE=ai_reply_suggestions
SUPABASE_PROFILE_TABLE=business_profiles
SUPABASE_COMMENT_LOG_TABLE=comment_logs
SUPABASE_COMMENT_SUMMARY_TABLE=post_comment_summaries
SUPABASE_POST_COMMENT_TABLE=post_comments
SUPABASE_STAFF_TABLE=staff_users
SUPABASE_CHANNEL_TABLE=managed_channels
SUPABASE_COMMENT_IMAGE_BUCKET=comment-images
MAX_COMMENT_IMAGE_BYTES=8388608
APP_SECRET_KEY=change_this_to_a_long_random_string
SIMPLE_LOGIN_ONLY=true

# Pick the provider in the app UI, then set the matching key here or in Vercel Environment Variables.
WEB_UI_URL=http://localhost:3000
USE_LEGACY_UI=false

# Experimental TikTok browser automation.
# Best used on a local machine/VPS with a real Chrome profile, not Vercel serverless.
TIKTOK_PLAYWRIGHT_ENABLED=false
TIKTOK_PLAYWRIGHT_HEADLESS=false
TIKTOK_PLAYWRIGHT_USER_DATA_DIR=data/playwright/tiktok-profile
TIKTOK_PLAYWRIGHT_TIMEOUT_MS=60000

GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
CLAUDE_API_KEY=your_claude_api_key
