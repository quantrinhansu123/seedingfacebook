{
  "manifest_version": 3,
  "name": "Seeding Fsolution Bridge",
  "version": "0.1.17",
  "description": "Ket noi Seeding Fsolution voi phien dang nhap Chrome that cho Facebook/TikTok.",
  "permissions": ["tabs", "scripting", "cookies"],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://www.facebook.com/*",
    "https://*.facebook.com/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.vercel.app/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["web-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["tiktok-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Seeding Fsolution Bridge",
    "default_popup": "popup.html"
  }
}

